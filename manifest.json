{
  "manifest_version": 3,
  "name": "GA Opt-Out (Per Site)",
  "short_name": "GA Opt-Out",
  "version": "1.0.0",
  "author": "Quantable",
  "homepage_url": "https://github.com/jhpacker/ga-optout-persite",
  "description": "Sends recognized Google Analytics data collection requests to a local file rather than to Google. Stops your data from reaching Google but allows you to see what would have been sent to Google.",
  "permissions": [
    "declarativeNetRequest",
    "webRequest",
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "GA Opt-Out (Per Site)",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["null-hit-sink.txt"],
      "matches": ["<all_urls>"]
    }
  ]
}
